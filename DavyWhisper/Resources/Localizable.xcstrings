 for %@": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "%@ 的设置"}}}}, "Processing transcription": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "正在转录"}}}}, "Processing...": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "处理中..."}}}}, "Processed": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "已处理"}}}}, "Error: %@": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "错误：%@"}}}}, "Show terms for %@": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "显示 %@ 的术语"}}}}, "Pending": {"comment": "A label indicating that a file is currently being processed.", "isCommentAutoGenerated": true, "localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "等待中"}}}}, "Transcribing...": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "转录中..."}}}}, "Transcription complete, %lld words": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "转录完成，%lld 个词"}}}}, "Playback position": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "播放位置"}}}}, "Recording timer": {"comment": "A label describing the timer that appears when recording audio.", "isCommentAutoGenerated": true, "localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "录音计时器"}}}}, "Collapsed": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "已折叠"}}}}, "Idle": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "空闲"}}}}, "Edit %@": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "编辑 %@"}}}}, "Search prompts": {"comment": "A label for a text field used to search through a list of prompts.", "isCommentAutoGenerated": true, "localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "搜索提示词"}}}}, "Reads back the transcribed text via speech synthesis after each dictation.": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "每次听写后通过语音合成朗读转录文本。"}}}}, "Inserting text": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "正在插入文本"}}}}, "Active profile": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "活动配置文件"}}}}, "Current shortcut: %@. Click to change.": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "当前快捷键：%@。点击更改。"}}}}, "Uninstall %@": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "卸载 %@"}}}}, "© 2024-2026 DavyWhisper Contributors": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "© 2024-2026 DavyWhisper 贡献者"}}}}, "Recording Start": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "录音开始"}}}}, "Transcription Success": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "转录成功"}}}}, "Transcription success": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "转录成功"}}}}, "Preview sound": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "预览声音"}}}}, "Add custom sound": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "添加自定义声音"}}}}, "Choose a sound file": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "选择声音文件"}}}}, "Prompts & AI": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "提示词与 AI"}}}}, "Process your dictated text with AI - translate, reformat, summarize, and more.": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "使用 AI 处理您的听写文本 - 翻译、重新格式化、总结等。"}}}}, "You have an LLM provider ready.": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "您已有一个 LLM 提供商就绪。"}}}}, "Already Installed": {"localizations": {"zh-Hans": {"stringUnit": {"state": "translated", "value": "已安装"}}}}, "Free API 